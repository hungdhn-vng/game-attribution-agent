GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=
# GreenNode AI Platform (MaaS) — OpenAI-compatible. Use /agentbase-llm to get a key + model.
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=
# Optional conversation memory (use /agentbase-memory to create); blank = local MemorySaver
MEMORY_ID=

# ── Async analysis pipeline ───────────────────────────────────────────────────
# Number of synthesis samples for self-consistency gate (default 3)
GAA_N_SAMPLES=3
# Per-request wall-clock budget in seconds before the pipeline suspends (default 40)
GAA_REQUEST_BUDGET_S=40

# ── Live market benchmark (set GAA_BENCHMARK_MODE=crawl to enable) ────────────
# Default (unset / empty): bundled snapshot floor only; no outbound HTTP for benchmarks.
# Set to "crawl" to enable live Roblox + Steam crawl on each analyze call.
GAA_BENCHMARK_MODE=crawl

# Roblox tracker URL templates ({genre} and {id} are substituted at runtime)
# GAA_ROBLOX_DISCOVER_URL_TMPL=https://example.com/roblox/discover?genre={genre}
# GAA_ROBLOX_SERIES_URL_TMPL=https://example.com/roblox/series?id={id}

# Steam tracker URL templates ({genre} and {id} are substituted at runtime)
# GAA_STEAM_DISCOVER_URL_TMPL is unused — Steam discovery uses the built-in curated genre map.
# GAA_STEAM_SERIES_URL_TMPL=https://steamcharts.com/app/{id}/chart-data.json

# ── Perplexity (external, web tier) — qualitative benchmark fallback ──────────
# Leave blank to disable the Perplexity web tier.
PERPLEXITY_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to "1" to stream model reasoning to stdout (debugging only)
GAA_SHOW_MODEL_REASONING=
